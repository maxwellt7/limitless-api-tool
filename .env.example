# Limitless API credentials (required)
LIMITLESS_API_KEY=your_limitless_api_key_here

# Notion API credentials (optional, for Notion sync)
NOTION_API_KEY=your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_database_id_here

# Mem.ai API credentials (optional, for Mem.ai sync)
MEM_API_KEY=your_mem_api_key_here

# OpenAI API key (optional, for summarize functionality)
OPENAI_API_KEY=your_openai_api_key_here

# Optional settings
# LIMITLESS_API_URL=https://api.limitless.ai  # Only needed if using a custom API URL
